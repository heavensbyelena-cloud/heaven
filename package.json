{
  "name": "heaven-by-elena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "build:cf": "next build && rimraf .next/cache && npx opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "deploy": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && wrangler deploy --yes",
    "preview": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && opennextjs-cloudflare preview",
    "cf:secrets": "wrangler secret bulk .env.local",
    "deploy:win": "powershell -ExecutionPolicy Bypass -File deploy.ps1"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.6.1",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.43.0",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "jose": "^5.10.0",
    "next": "^16.1.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.0",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0",
    "wrangler": "^4.65.0"
  }
}
